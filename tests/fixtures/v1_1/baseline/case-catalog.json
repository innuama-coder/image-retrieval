{
  "schema_version": 1,
  "suite_id": "baseline_recall_v1_1",
  "description": "Baseline capability cases for candidate recall, candidate retrieval, and delivery.",
  "units": [
    "candidate_recall",
    "candidate_retrieval",
    "delivery"
  ],
  "default_report_dir": "target/baseline-reports",
  "metric_definitions": {
    "expected_candidate_recall": "must_recall candidates found after provider parsing, dedupe, and candidate evaluation.",
    "precision_at_10": "Fraction of top 10 retrievable candidates expected to be relevant.",
    "duplicate_rate": "Duplicate candidates divided by raw candidates.",
    "retrieval_success_rate": "Complete local artifacts divided by retrieval jobs.",
    "failure_classification_accuracy": "Retrieval failures matching expected reason codes.",
    "delivery_recall": "must_deliver images accepted into the package.",
    "delivery_precision": "Accepted images that are expected-good deliveries."
  },
  "cases": [
    {
      "case_id": "cr_simple_product_clean",
      "unit": "candidate_recall",
      "supported_test_types": ["unit", "scenario_fixture", "scenario_real_service"],
      "query_plan": {
        "description": "red apple on a plain white background",
        "query_texts": ["red apple white background", "single red apple isolated"],
        "required_image_count": 1,
        "quality": "general",
        "quality_requirements": {
          "minimum_width": 600,
          "minimum_height": 600,
          "allow_thumbnail_only": false
        },
        "visual_requirements": ["single object", "plain background"],
        "negative_scope": ["basket", "tree", "text overlay"]
      },
      "difficulty_profile": {
        "search": "clean_high_relevance",
        "retrieval": "direct_ok",
        "evaluation": "low_ambiguity"
      },
      "fixtures": {
        "provider_response": "provider-responses/baseline/candidate_recall/simple_product_clean_serpapi.json",
        "scorer": "fixture_candidate_scorer"
      },
      "gold_labels": {
        "must_recall": ["apple-clean-001", "apple-clean-002"],
        "acceptable": ["apple-clean-003"],
        "must_reject": ["apple-tree-001", "apple-text-001"],
        "duplicates": [
          {
            "candidate_id": "apple-dup-002",
            "duplicate_of": "apple-clean-001"
          }
        ]
      },
      "expected_metrics": {
        "min_unique_candidate_count": 20,
        "expected_candidate_recall_min": 1.0,
        "precision_at_10_min": 0.8,
        "duplicate_rate_max": 0.25,
        "score_mae_max": 0.1
      },
      "analysis_tags": ["easy_recall", "product_image", "negative_scope"]
    },
